  </div>
</div>

<!-- DRAWER FORMULAIRE -->
<div class="form-overlay" id="overlay">
  <div class="form-backdrop" id="backdrop"></div>
  <div class="form-drawer">
    <div class="drawer-header">
      <div>
        <div class="drawer-title">Votre candidature</div>
        <div class="drawer-domain" id="drawer-domain"></div>
      </div>
      <button class="drawer-close" id="drawer-close">✕</button>
    </div>
    <div class="drawer-body">
      <form id="form">
        <div class="frow">
