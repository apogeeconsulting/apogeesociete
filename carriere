            <div class="fg">
              <label for="itype">Type de profil *</label>
              <select id="itype" name="itype">
                <option value="" disabled selected>Sélectionnez</option>
                <option>Candidat en remote depuis l'étranger</option>
                <option>Partenaire / ambassadeur local</option>
                <option>Porteur de projet filiale Apogée</option>
              </select>
            </div>
          </div>
        </div>

        <div class="frow full">
          <div class="fg">
            <label for="msg">Parcours &amp; motivations *</label>
            <textarea id="msg" name="msg" placeholder="Dites-nous qui vous êtes…" required></textarea>
          </div>
        </div>

        <div class="consent">
          <input type="checkbox" id="rgpd" required>
          <span>J'accepte l'utilisation de mes données pour ma candidature — <a href="https://www.apogee-societe.com/politiquedeconfidentialité" target="_blank">confidentialité</a>.</span>
        </div>

        <button type="submit" class="btn-send">
          Envoyer
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </form>

      <div class="success" id="success">
        <div class="s-ring"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
        <h3>Reçue.</h3>
        <p>Merci pour votre intérêt.<br>Nous revenons vers vous rapidement.</p>
      </div>
    </div>
  </div>
</div>

<script>
// ── TABS
function switchTab(name){
  document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab===name));
  document.querySelectorAll('.panel').forEach(p => p.classList.toggle('active', p.id==='panel-'+name));
}
document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

// ── DRAWER
const overlay = document.getElementById('overlay');
const domSelect = document.getElementById('domaine');

function openDrawer(domaine, intlType){
  // reset formulaire visuel
  intlOpen = false;
  document.getElementById('itrack').classList.remove('on');
  document.getElementById('ifields').classList.remove('open');
  document.getElementById('pays').required = false;
  document.getElementById('itype').required = false;
  document.getElementById('intl-section').style.display = 'none';

  // pré-remplir et verrouiller le domaine
  for(let o of domSelect.options){ o.selected = o.value === domaine; }
  domSelect.disabled = true;
  document.getElementById('drawer-domain').textContent = domaine;

  // international : activer uniquement si vient d'une carte intl
  if(intlType){
    document.getElementById('intl-section').style.display = 'block';
    intlOpen = true;
    document.getElementById('itrack').classList.add('on');
    document.getElementById('ifields').classList.add('open');
    document.getElementById('pays').required = true;
    document.getElementById('itype').required = true;
    const s = document.getElementById('itype');
    for(let o of s.options){ o.selected = o.value === intlType; }
  }

  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeDrawer(){
  overlay.classList.remove('open');
  document.body.style.overflow = '';
  domSelect.disabled = false;
  document.getElementById('itype').disabled = false;
}
document.getElementById('backdrop').addEventListener('click', closeDrawer);
document.getElementById('drawer-close').addEventListener('click', closeDrawer);

// ── DOMAINES → domaine verrouillé, pas de section internationale
document.querySelectorAll('.dom-row[data-domaine]').forEach(row => {
  row.addEventListener('click', function(){
    openDrawer(this.dataset.domaine, null);
  });
});

// ── CARTES INTERNATIONALES → domaine = spontanée + toggle activé + type verrouillé
document.querySelectorAll('.intl-card[data-intl]').forEach(card => {
  card.addEventListener('click', function(){
    const intlType = this.dataset.intl;
    openDrawer('Candidature spontanée', intlType);
    // verrouiller le select type de profil
    const s = document.getElementById('itype');
    s.disabled = true;
  });
});

// ── TOGGLE (uniquement si affiché)
let intlOpen = false;
const itoggle = document.getElementById('itoggle');
itoggle.addEventListener('click', function(){
  intlOpen = !intlOpen;
  document.getElementById('itrack').classList.toggle('on', intlOpen);
  document.getElementById('ifields').classList.toggle('open', intlOpen);
  itoggle.setAttribute('aria-expanded', intlOpen);
  document.getElementById('pays').required  = intlOpen;
  document.getElementById('itype').required = intlOpen;
});

// ── SUBMIT
document.getElementById('form').addEventListener('submit', function(e){
  e.preventDefault();
  const d  = new FormData(this);
  const g  = k => (d.get(k)||'Non renseigné').trim();
  const il = intlOpen
    ? 'Pays : '+g('pays')+' / Ville : '+g('ville')+' / Profil : '+g('itype')
    : 'Basé en France';
  const subject = 'Candidature - '+g('prenom')+' '+g('nom')+' - '+g('domaine');
  const body = [
    'CANDIDATURE - APOGEE SOCIETE',
    '---',
    'Nom : '+g('prenom')+' '+g('nom'),
    'Email : '+g('email'),
    'Tel : '+g('tel'),
    '---',
    'Domaine : '+g('domaine'),
    'Experience : '+g('exp'),
    'Disponibilite : '+g('dispo'),
    'Mode : '+g('mode'),
    'Localisation : '+il,
    '---',
    g('msg'),
    '---',
    'apogee-societe.com/recrutement'
  ].join('%0D%0A');
  const a = document.createElement('a');
  a.href = 'mailto:contact@apogee-societe.fr?subject='+encodeURIComponent(subject)+'&body='+body;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  this.style.display = 'none';
  document.getElementById('success').style.display = 'block';
});
</script>
</body>
</html>
