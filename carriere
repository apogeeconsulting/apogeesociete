          <span class="dr-arr">→</span>
        </div>
        <div class="dom-row" data-domaine="Comptabilité / Finance">
          <div class="dr-left"><span class="dr-num">03</span><span class="dr-name">Comptabilité &amp; Finance</span></div>
          <span class="dr-arr">→</span>
        </div>
        <div class="dom-row" data-domaine="Juridique">
